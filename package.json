{
  "name": "front-end-app",
  "version": "1.15.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "test:coverage": "pnpm run coverage",
    "lint": "eslint \"src/**/*.{ts,html}\"",
    "format:check": "prettier --check .",
    "lint:fix": "eslint 'src/**/*.{ts,html}' --fix",
    "preview": "vite preview",
    "prettier:write": "prettier --write \"src/**/*.{ts,html,json,css,scss}\"",
    "format": "prettier --write .",
    "prepare": "husky install",
    "increment-version": "pnpm dlx ts-node --project tsconfig.scripts.json scripts/bump-version.ts"
  },
  "lint-staged": {
    "src/**/*.{ts}": [
      "pnpm lint",
      "git add"
    ],
    "src/**/*.{ts,html,scss,json,css,md,yml,yaml}": [
      "pnpm prettier:write",
      "git add"
    ]
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "pnpm": {
    "overrides": {
      "tar": ">=7.5.7",
      "lodash": ">=4.17.23",
      "undici": ">=7.18.2",
